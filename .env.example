# Telegram Bot Configuration
TELEGRAM_TOKEN=your_telegram_bot_token_here

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_BASE_URL=https://res.cloudinary.com/your_cloud_name/image/upload

# Blockchain Configuration
BLOCKCHAIN_NETWORK=sepolia
NFT_CONTRACT_ADDRESS=0xYourContractAddressHere
YOUR_WALLET_ADDRESS=0xYourWalletAddressHere
NFT_PRICE=0.001

# RPC URLs (choose your provider)
SEPOLIA_RPC_URL=https://rpc.sepolia.org
MAINNET_RPC_URL=https://rpc.ankr.com/eth

# Bot Wallet (for paying gas fees)
BOT_WALLET_PRIVATE_KEY=0xYourPrivateKeyHere

# Optional: Block Explorer API Keys
BSCSCAN_API_KEY=your_bscscan_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key
