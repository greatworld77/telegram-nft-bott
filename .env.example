# Telegram (REQUIRED)
TELEGRAM_TOKEN=your_unified_bot_token_here

# MongoDB (REQUIRED)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/

# Cloudinary (REQUIRED)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Novita AI (REQUIRED for AI generation)
NOVITA_API_KEY=your_novita_api_key

# Blockchain (REQUIRED for NFT minting)
BLOCKCHAIN_NETWORK=sepolia
NFT_CONTRACT_ADDRESS=0xYourContractAddress
YOUR_WALLET_ADDRESS=0xYourWalletAddress
NFT_PRICE=0.001
BOT_WALLET_PRIVATE_KEY=0xYourPrivateKey

# RPC URLs
SEPOLIA_RPC_URL=https://rpc.sepolia.org
MAINNET_RPC_URL=https://rpc.ankr.com/eth
